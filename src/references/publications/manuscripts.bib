@unpublished{mongeon2015designing,
  title={Designing Effective Sport Teams through Physical Diversity},
  author = {Mongeon, Kevin and Boyle, J. Michael},
  abstract={This paper examines the impact of diversity amongst the physical characteristics of players on National Hockey League team rosters on winning. The results suggest that less height, more weight, and less age diverse teams have a greater likelihood of winning games. Moreover, team rosters comprised of taller, lighter, and younger players win more games in comparison to shorter, heavier, and older team rosters. The results are robust across numerous model specifications based on both game and within-game information. The findings are presented in real terms based on their associated win probability increments/decrements.},
  addendum = {Contribution percentage: 80},
 keywords = {manuscript}
}

@unpublished{mitchell2015peer,
  title={Effects of Peer Academic Support on University Course Grades},
  author = {Mitchell, Georgina and Mongeon, Kevin and McCluskey, Jill and Giannetto, Michael},
  abstract = {This study estimates the impact of peer academic support on university course grades.  Results suggest that, on average, about twelve peer academic support sessions increase a student’s course grade by approximately one full grade point, holding constant a student’s academic ability and socioeconomic status.  Supplemental instruction is potentially a more effective method of peer academic support than individual peer academic support sessions and low-performing students benefit more from peer academic support than high-performing students.}, addendum = {Contribution percentage: 30},
 keywords = {manuscript}
}


