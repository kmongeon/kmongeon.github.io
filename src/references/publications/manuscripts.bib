@unpublished{mongeon2015preservation,
  title={Rationally Biased Officiating for Preservation and Profit},
  author = {Kevin Mongeon and Ron Mittelhammer},
  abstract = {A dynamic stochastic decision model motivates an empirical analysis that provides evidence of explicit forms of “biases” exhibited by game officials. Using a case study based on real-time decision making by referees in the NHL, new evidence is found that decisions by game officials deliberatively favor the home team, promote close games, and officials tend to balance penalty calls between competing teams, which creates a perception of fairness and objectivity that can mute scrutiny of penalty calling biases. The biases can be viewed as rational in the context of supplying game characteristics while also supporting job preservation of officials.}, addendum = {Contribution percentage: 75},
 keywords = {manuscript}
}

@unpublished{mongeon2015omission,
  title={Rational Omission Biased Officiating in the NHL},
  author = {Mongeon, Kevin and Ron Mittelhammer and Jill McCluskey},
  abstract = {Both parametric and semi-parametric duration models are used to provide empirical evidence that professional hockey referees succumb to the cognitive bias of omission bias in penalty calling.  Rather than being seen as displaying characteristics that can be deemed sub-optimal or to showcase errors in judgment, the referees’ working environment is conducive to the manifestation of such a bias in that it insulates them from criticism, and their behavior can be interpreted as rational in the context of their preserving future employment.  There is also a possibility that fans demand omission bias in officiating, which creates conflicting incentives for the league in terms of both governing referees to officiate in a manner that will achieve fair game outcomes while simultaneously maximizing profits.  Separating the evaluation of officiating from the league is one policy option.}, addendum = {Contribution percentage: 60},
 keywords = {manuscript}
}

@unpublished{Ludwa2017bone,
  title={Longitudinal  Examination of the Bone Mechanostat Theory in Children},
  author = {Izabella Ludwa and Kevin Mongeon and Bareket Falk and Panagiota Klentrou},
  abstract={This study provides experimental evidence in support of the conceptual functional model of bone development postulating that the primary mechanical challenges to bone’s mechanostat during growth is increases in muscle force. This longitudinal study measured radial and tibial bone properties, isometric grip and knee extensors strength, and maturity in 172 children aged 8-15 years 2-3 times over a period of 3 years. Both the conceptual model and research design motivates the multilevel structural equation that explicates the relationship between strength and physical maturation on bone properties.}, 
  addendum = {Contribution percentage: 25},
 keywords = {manuscript}
}

@unpublished{mitchell2017dropout,
  title={The Impact ff Native American Casinos on the  Dropout Rate of Native High School Students},
  author = {Georgina Mitchell and Jill McCluskey and Kevin Mongeon},
  abstract={Native American high school students have the highest dropout rates of any race in the United States.  Many Native American high school students receive cash payouts from Indian Casino profits.  In this article, we analyze the impact of the size and payout requirements of trust funds on the dropout rate of Native American high school students.  Tribes that make per capita payments to enrolled members must decide how to distribute the per capita payments to minor children.  Tribes can pay the funds to the minor, deposit the funds in a trust fund or pay part of the funds and deposit the rest.  If the minors have trust funds, the tribe has to decide the requirements the minor must meet in order to withdraw funds. Tribes have age requirements and/or high school graduation requirements.}, addendum = {Contribution percentage: 25},
 keywords = {manuscript}
}

@unpublished{cullen2017attraction,
  title={The Sport Attraction: The Impact of Overall Collegiate Athletic Success on Student Applications},
  author = {Kelley Cullen and Jill McCluskey and Kevin Mongeon},
  abstract={Students consider many factors in their choices of colleges to which they will apply.  Practical issues, including tuition, financial aid, geography, and size, are typically important.  Previous research shows that universities with successful men’s basketball or football programs tend to attract larger pools of applicants.  The cause may be attributable to the institution’s increased exposure during its successful athletic season.  However, not all sports receive this exposure.  This study examines whether overall success in athletic programs increases the number and/or quality of applicants.  We find that the overall athletic success has a positive effect on quality but not quantity.}, addendum = {Contribution percentage: 30},
 keywords = {manuscript}
}
