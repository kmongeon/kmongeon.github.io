
@article{boyle2013Growing,
  title={Growing an Organization's Sports Analytics Competency},
  author = {Michael Boyle and Kevin Mongeon},
  journal={Sports Performance \& Tech},
  volume={1},
  number={2},
  pages={27--32},
  year={2013},
  abstract = {Many sports organizations have had varying levels of success whilst integrating analytics into their decision-making processes. The issue that many are finding is that challenges executing on analytics projects are different and often more difficult than traditional projects. Fortunately, there are some who have learned how to overcome these challenges and maximise the benefits of analytics adoption. Through collaborating with analytics experts globally, a number of best practices have been created to help teams, franchises and businesses with their implementation. We outline some of these best practices and our experiences in creating the Sports Analytics Program Management (SAPM) framework.},
    addendum = {Magazine. Contribution percentage: 40},
keywords = {publication, other, magazine}
}

@inproceedings{mongeon2013derived,
  title={Hockey Analytics: Derived Statistics are the Beginning not the End},
  author = {Mongeon, Kevin},
  booktitle={2013 MIT Sloan Sports Analytics Conference},
  year={2013},
  howpublished = {Online},
  abstract = {A large portion of the efforts of sports analytics specialists is focused on determining the value of a player, or more specifically, a player’s contribution to winning.  This article explains how analysts have created a number of derived statistics that potentially determine a player’s contribution to winning more accurately than traditional statistics.},
  url = {www.sloansportsconference.com/?p=9862},
  addendum = {Online. Contribution percentage: 100},
  keywords = {publication, other, online}
}
