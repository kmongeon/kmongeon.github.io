@article{mongeon2016ohl,
	title={Expert Report on the Economics of the Canadian Hockey League and its Team 	Members},
	author={Mongeon, Kevin},
	journal={Berg v. Canadian Hockey League},
	volume={2016 ONSC 4466},
	year ={2016},
	abstract = {My examination of the economic environments and the business operations of the OHL, WHL and their member teams led to the following conclusions: 1. All players contribute to the value of all teams within their league. 2. Teams consistently interact with players in the common. 3. The Leagues and their member teams make decisions to maximize profits. 4. A minimum wage is a viable policy that will have a negligible effect on the provision of teams. I arrive at these conclusions through the construction of models and the observation of data. I do not attempt to account for private financial data from individual teams, nor do I want these data because they reflect accounting practices rather than responses to the incentives of leagues and teams. The issue of player pay concerns players' contributions to the economic production of games and revenues.},
	url = {http://www.chlclassaction.com/court-record/},
    addendum = {Contribution percentage: 100},
    keywords = {publication, report}

}

