
@misc{fogel2017sshrc_work,
  title={Rink Rage: Spectator Violence and Harassment in Canadian Youth Hockey},
  author = {Fogel, Curtis and Mongeon, Kevin},
  howpublished={Social Sciences and Humanities Research Council Insight Development Grant},
  year={2017},
  month = {11}, 
  note = {\$97,000},
  abstract = {During an amateur hockey game involving 10-year-old boys, an upset hockey dad, Thomas Junta, entered the ice surface to confront his son’s coach, Michael Costin. A physical altercation ensued in which Junta repeatedly hit Costin in the face and head knocking him unconscious. Costin died of his injuries, leading to Junta receiving a criminal conviction of manslaughter (Commonwealth v. Junta, 2004). The tragic incident made headlines around the world of what was largely portrayed as an isolated incident of a single hockey parent acting out in uncommon rage. While the death that resulted in the Junta incident of rink rage was uncommon, injurious violence perpetrated by spectators in youth hockey is not. Canadian law reports reveal incidences of serious physical violence perpetrated by spectators in youth hockey against: i) players, ii) coaches , iii) referees , iv) mascots, and v) other spectators. Our preliminary research has revealed 68 separate legal cases of what could be called rink rage, defined as hockey spectators acting in criminally violent and aggressive ways during and in the immediate aftermath of youth hockey games. Media reports reveal many other cases that are not published as law reports. For example, in a recent youth hockey game in British Columbia an all-out brawl between hockey parents in the stands broke out (Jones, 2016). A hockey dad/police officer threatened to kill a referee . And, a parent placed a bounty on the head of nine-year-old after his son was hit during a post-game handshake ritual.},
   addendum = {Contribution percentage: 40}, 
  keywords = {egrant}
}
@misc{fogel2017sshrc,
  title={Rink Rage: Spectator Violence and Harassment in Canadian Youth Hockey},
  author = {Fogel, Curtis and Mongeon, Kevin},
  howpublished={Brock University Social Sciences and Humanities Research Council Institutional Grant},
  year={2017},
  month = {05}, 
  note = {\$7,500}, 
  abstract={We propose to examine spectator violence in Canadian ice hockey. Legal and media files from 65 cases will be analyzed to determine the prevalence and cause of spectator violence against players, coaches, referees, mascots, other spectators, and property. The analysis will consider various contributing factors including alcohol consumption, over-identification as part of the team, over-conformity to the ethic of sport spectatorship, socio-economic status, social tolerance, and masculine identity maintenance. We also aim to identify the response of Canadian hockey organizations and legal officials and offer various prevention strategies. },   
  addendum = {Contribution percentage: 25},
  keywords = {igrant}
}


@misc{mongeon2015sshrc,
  title={Building Bayesian Updating Models and Testing for Biases: The Case of Sports Betting Markets},
  author = {Mongeon, Kevin and Mittelhammer, Ron and Boyle, Michael J.},
  howpublished={Social Sciences and Humanities Research Council Insight Development Grant},
  year={2015},
  month = {6}, 
  note = {\$50,750},
  abstract={The central aim of this project is to expand our understanding of dynamic decision-making processes under uncertainty by measuring the extent to which information processing biases, in aggregate, are reflected in asset prices. This knowledge will empower people to make improved decisions in complex scenarios that require constant information updating.  To generate this knowledge, we propose to merge experimental research, which examines the decision-making process, and behavioural finance/economics research, which examines the impact of decision-making outcomes. By combining these approaches, we aim to generate new knowledge that will be relevant to scholars, industry actors and members of the general public who actively engage in situations involving substantive decision-making under uncertainty.},
  addendum = {Contribution percentage: 90},
  keywords = {egrant}
}

@misc{BSIG2014,
  title={Bettors Over-Reaction to Changes in Short-Term Market Conditions},
  author = {Mongeon, Kevin and Mittelhammer, Ron and Boyle, Michael J.},
  howpublished={Brock University Social Sciences and Humanities Research Council Institutional Grant},
  year={2014},
  month = {10}, 
  note = {\$4,970},  
  abstract={This study proposes to identify whether or not sports bettors exhibit the behavioural bias of overreaction to short-term market conditions. If the bias is present, the study will determine the amount of time it takes for the market to (potentially) reach a new equilibrium price that accurately reflects the underlying value of the asset. It will also determine whether or not the obtainment of abnormal profit is possible.}, addendum = {Contribution percentage: 75},
  keywords = {igrant}
}

